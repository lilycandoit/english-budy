generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooled connection — used at runtime
  directUrl = env("DIRECT_URL")         // direct connection — used only for db:push
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hashed; null for OAuth users
  groqApiKey    String?   // AES-256-GCM encrypted
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  mistakes         Mistake[]
  learningSessions LearningSession[]
  wordEntries      WordEntry[]
  topicSessions    TopicSession[]
  reviewSessions   ReviewSession[]
  flashcardReviews FlashcardReview[]
  wordSchedules    WordSchedule[]
}

model Mistake {
  id             String   @id @default(cuid())
  userId         String
  originalText   String   @db.Text
  correctedText  String   @db.Text
  naturalText    String?  @db.Text
  mistakeType    String   // "grammar" | "spelling" | "punctuation" | "none"
  explanation    String   @db.Text
  naturalnessTip String?  @db.Text
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Required by NextAuth + PrismaAdapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningSession {
  id        String      @id @default(cuid())
  userId    String
  words     String      @db.Text // JSON: string[]
  wordInfo  String      @db.Text // JSON: WordInfo[]
  quiz      String?     @db.Text // JSON: QuizQuestion[]
  createdAt DateTime    @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizResult QuizResult?

  @@index([userId, createdAt])
}

model QuizResult {
  id        String          @id @default(cuid())
  sessionId String          @unique
  score     Int
  total     Int
  answers   String          @db.Text // JSON
  createdAt DateTime        @default(now())

  session LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model WordEntry {
  id        String   @id @default(cuid())
  userId    String
  word      String
  wordInfo  String   @db.Text // JSON: WordInfo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId, updatedAt])
}

model TopicSession {
  id        String   @id @default(cuid())
  userId    String
  topic     String
  format    String   // "dialog" | "story"
  title     String
  content   String   @db.Text
  words     String   @db.Text // JSON: TopicWord[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model ReviewSession {
  id        String   @id @default(cuid())
  userId    String
  words     String   @db.Text // JSON: string[]
  story     String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model FlashcardReview {
  id        String   @id @default(cuid())
  userId    String
  word      String
  result    String   // "known" | "review"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model WordSchedule {
  id             String   @id @default(cuid())
  userId         String
  word           String
  easeFactor     Float    @default(2.5)
  intervalDays   Int      @default(1)
  repetitions    Int      @default(0)
  nextReviewAt   DateTime
  lastReviewedAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId, nextReviewAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
