# ── Database (Neon PostgreSQL) ──────────────────────────────
# In Neon dashboard: Connection Details → toggle "Pooled connection"
# DATABASE_URL = the POOLED connection string (hostname contains "-pooler")
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=10"
# DIRECT_URL = the DIRECT connection string (no -pooler, used only for db:push)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ── NextAuth ────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, NEXTAUTH_URL is set automatically — you can omit it there

# ── Encryption key for Groq API keys ────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-key-here"

# ── Optional: Google OAuth ───────────────────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
